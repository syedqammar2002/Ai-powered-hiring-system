# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Connection
# For local: mongodb://127.0.0.1:27017/ai_hiring_system
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/ai_hiring_system
MONGO_URI=mongodb://127.0.0.1:27017/ai_hiring_system

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_2026
SESSION_SECRET=your_session_secret_key_2026

# Email Configuration (Gmail SMTP)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password

# Admin Registration Secret
ADMIN_REGISTER_SECRET=my_super_secret_admin_code_2026

# Frontend URL (for CORS and redirects)
# For local development: http://localhost:5173
# For Vercel production: https://your-app-name.vercel.app or your custom domain
FRONTEND_URL=http://localhost:5173

# Optional: AI Service URL (if running separately)
# AI_SERVICE_URL=http://localhost:8000

# Render.com Deployment Notes:
# 1. Set NODE_ENV=production on Render
# 2. Use MongoDB Atlas URI instead of local MongoDB
# 3. Update FRONTEND_URL to your Vercel domain
# 4. All other secrets should be set in Render Environment variables
